rules_version = '2';

function isAdmin() {
  return request.auth != null &&
    request.auth.uid in [
      "SiKBK55SvDeqSd96KgCMbZzaj8n1"
    ];
}

service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Création publique (le checkout tourne sans compte utilisateur),
      // mais on borne la forme du document pour éviter les abus basiques.
      allow create: if
        request.resource.data.orderNumber is string &&
        request.resource.data.contact is string &&
        request.resource.data.items is list &&
        request.resource.data.status == "en_attente" &&
        request.resource.data.totalEUR is number &&
        request.resource.data.totalEUR >= 0;

      allow get: if true;
      allow list: if isAdmin();

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow create: if
        request.resource.data.contact is string &&
        request.resource.data.message is string;
      allow read, update, delete: if isAdmin();
    }
  }
}
